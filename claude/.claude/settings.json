{
  "permissions": {
    "allow": [
      "mcp__whiteboard__*"
    ],
    "defaultMode": "auto"
  },
  "enabledPlugins": {
    "astral@astral-sh": true,
    "ast-grep@ast-grep-marketplace": true
  },
  "extraKnownMarketplaces": {
    "astral-sh": {
      "source": {
        "source": "github",
        "repo": "astral-sh/claude-code-plugins"
      }
    },
    "ast-grep-marketplace": {
      "source": {
        "source": "github",
        "repo": "ast-grep/agent-skill"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/activate-skills.py"
          }
        ]
      }
    ]
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "medium",
  "advisorModel": "opus",
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": false,
  "preferredNotifChannel": "kitty"
}
